# COGNEE_MODE=selfhosted (default) talks to your own cognee-service (real,
# self-hosted OSS cognee). Set to "cloud" to fall back to Cognee Cloud below
# -- fallback only, per this project's "self-hosted OSS" goal.
COGNEE_MODE="selfhosted"
COGNEE_SELFHOSTED_URL="http://localhost:8000/api/v1"

# Cognee Cloud URL (fallback only -- see COGNEE_MODE above)
COGNEE_API_URL="https://your-tenant.aws.cognee.ai/api/v1"
COGNEE_TENANT_ID="your_tenant_id"
COGNEE_USER_ID="your_user_id"
COGNEE_API_KEY="your_cognee_cloud_api_key"

# Onto API Key (required for real trust scoring; falls back to mock data if unset)
ONTO_API_KEY="your_onto_api_key"

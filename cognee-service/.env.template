# Copy to .env and fill in the two keys marked below.
#
# --- LLM: native OpenAI provider (LLMProvider.OPENAI in cognee's own enum --
# see get_llm_client.py). We started on Groq via the "custom" provider path,
# but its default instructor mode ("json_mode", pure prompt-engineered JSON)
# kept producing malformed output against our nested Person/Event/Place
# ontology, and the free Groq tier's 100k-tokens/day cap is easy to blow
# through on retries besides. Switched to OpenAI + gpt-5.4-mini and confirmed
# end-to-end on the full 15-fragment "Find Doug" set: clean single-pass
# extraction, correct multi-hop graph, and GRAPH_COMPLETION_CONTEXT_EXTENSION
# committed to the right answer instead of hedging.
LLM_PROVIDER="openai"
LLM_MODEL="gpt-5.4-mini"
LLM_API_KEY="your_openai_api_key"
# No LLM_ENDPOINT needed -- unset routes to OpenAI's real API.
#
# Instructor mode: intentionally left unset. Cognee's OpenAI adapter
# (openai/adapter.py) auto-selects "json_schema_mode" for any "gpt-5" model
# -- OpenAI's real Structured Outputs feature, schema-conformance-guaranteed
# server-side. Don't override this with LLM_INSTRUCTOR_MODE unless you
# change models.
#
# Groq fallback (kept for reference, not currently used):
#   LLM_PROVIDER="custom"; LLM_MODEL="groq/llama-3.3-70b-versatile"
#   LLM_ENDPOINT="https://api.groq.com/openai/v1"; LLM_API_KEY="your_groq_api_key"
#   LLM_INSTRUCTOR_MODE="tool_call"  # required fix for Groq's json_mode default

# --- Embeddings: Groq has no embeddings API. fastembed runs fully local,
# no key, no cost, and is the combo CI-proven in the upstream repo. ---
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS="384"
#
# On a memory-constrained host (e.g. Render's free 512MB tier), fastembed's
# local ONNX model can push the process over the limit under real load. Swap
# to routing embeddings through OpenAI's API instead (see render.yaml):
#   EMBEDDING_PROVIDER="openai"
#   EMBEDDING_MODEL="text-embedding-3-small"
#   EMBEDDING_DIMENSIONS="1536"

# --- Stores: all embedded/file-based, zero extra infra ---
# Verified against the actually-installed cognee==1.2.2 (not just docs):
# its real default graph store is "ladybug", not "kuzu" -- kuzu isn't even
# installed by this requirements.txt. Swap to "neo4j" (+ GRAPH_DATABASE_URL/
# _USERNAME/_PASSWORD) to show the swappable-store story on stage.
GRAPH_DATABASE_PROVIDER="ladybug"
VECTOR_DB_PROVIDER="lancedb"
DB_PROVIDER="sqlite"

# Per-dataset isolated stores. Cognee's own get_graph_data()/visualize_graph()
# have no dataset filter at all -- with this off, every dataset shares one
# physical graph store, so /datasets/{id}/graph leaks nodes across datasets
# (confirmed directly by ingesting into two datasets and seeing the first
# one's nodes bleed into the second's graph response). Access control scopes
# storage per (user, dataset) even with a single default user, so this has
# to be "true" for per-dataset graph isolation to be real, not just a
# talking point about ENABLE_BACKEND_ACCESS_CONTROL.
ENABLE_BACKEND_ACCESS_CONTROL="true"

# --- Onto (intake + trust scoring) ---
ONTO_API_URL="https://api.buildonto.dev"
ONTO_API_KEY="your_onto_api_key"
